{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run watch:*)",
      "Bash(gh run view:*)",
      "Bash(gh search:*)",
      "Bash(gh auth status:*)"
    ],
    "deny": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(gh api:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo rename:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release delete-asset:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh variable set:*)",
      "Bash(gh variable delete:*)",
      "Bash(gh workflow disable:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh ssh-key add:*)",
      "Bash(gh ssh-key delete:*)",
      "Bash(gh gpg-key add:*)",
      "Bash(gh gpg-key delete:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh codespace delete:*)",
      "Bash(gh project delete:*)",
      "Bash(gh extension install:*)",
      "Bash(gh extension upgrade:*)",
      "Bash(gh extension remove:*)",
      "Bash(gh extension exec:*)",
      "Bash(gh run delete:*)",
      "Bash(gh gist delete:*)",
      "Bash(gh label delete:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpx:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/notify.sh\" \"Task Complete\" \"Ready for review\" Glass Information 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/notify.sh\" \"Permission Needed\" \"Approve or deny\" Ping Warning 2>/dev/null || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/notify.sh\" \"Needs Input\" \"Waiting for you\" Pop Question 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "session-report@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true
  },
  "tui": "fullscreen",
  "skipAutoPermissionPrompt": true
}
