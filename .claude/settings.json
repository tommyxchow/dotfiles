{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpx:*)"
    ],
    "allow": [
      "WebFetch",
      "WebSearch"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/notify.sh\" \"Task Complete\" \"Ready for review\" Glass Information 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f=JSON.parse(require('fs').readFileSync(0,'utf8')).tool_input.file_path;const{execSync:r}=require('child_process');try{r('pnpm exec prettier --write --ignore-unknown '+JSON.stringify(f),{stdio:'ignore'})}catch{};try{r('pnpm exec eslint --fix '+JSON.stringify(f),{stdio:'ignore'})}catch{}\" 2>/dev/null; exit 0",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/notify.sh\" \"Permission Needed\" \"Approve or deny\" Ping Warning 2>/dev/null || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/notify.sh\" \"Needs Input\" \"Waiting for you\" Pop Question 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "session-report@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "enableWeakerNetworkIsolation": true
  },
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
